<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #1C1D21;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.miniproyecto_escritura_rapida.controller.WinController">
   <children>
      <ImageView fx:id="youWonImageView" fitHeight="400.0" fitWidth="600.0" layoutY="-3.0" pickOnBounds="true">
         <image>
            <Image url="@Images/win.jpg" />
         </image>
      </ImageView>
      <Label fx:id="youWonLabel" alignment="CENTER" contentDisplay="CENTER" layoutX="190.0" layoutY="62.0" text="¡Ganaste!" textAlignment="CENTER" textFill="#fff716">
         <font>
            <Font name="Berlin Sans FB" size="56.0" />
         </font>
         <effect>
            <Glow level="1.0" />
         </effect>
      </Label>
      <Button fx:id="playAgainButton" layoutX="228.0" layoutY="274.0" mnemonicParsing="false" onAction="#handlePlayAgain" prefHeight="32.0" prefWidth="142.0" text="Jugar de nuevo" />
      <Button fx:id="menuButton" layoutX="228.0" layoutY="323.0" mnemonicParsing="false" onAction="#handleMenu" prefHeight="32.0" prefWidth="142.0" text="Volver al menu" />
      <Label fx:id="congratsLabel" alignment="CENTER" contentDisplay="CENTER" layoutX="204.0" layoutY="176.0" prefHeight="42.0" prefWidth="190.0" text="¡Felicitaciones!" textAlignment="CENTER" textFill="#f4fff8">
